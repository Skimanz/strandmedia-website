<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Strand Media — Design Studio</title>
<link rel="icon" type="image/x-icon" href="favicon.ico">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate"/>
<meta http-equiv="Pragma" content="no-cache"/>
<meta http-equiv="Expires" content="0"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --orange:#E8441A;--orange-l:#FF5C2E;
  --charcoal:#2C2C2C;--dark:#1A1A1A;--mid:#666;
  --off-white:#F7F5F2;--white:#fff;
}
html{scroll-behavior:smooth;}
body{font-family:'Outfit',sans-serif;background:var(--off-white);color:var(--charcoal);overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 48px;height:72px;background:rgba(26,26,26,.96);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,.06);}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.nav-sq{width:14px;height:14px;background:var(--orange);}
.nav-txt{font-family:'Bebas Neue',sans-serif;font-size:22px;color:white;letter-spacing:.08em;}
.nav-links{display:flex;gap:36px;align-items:center;}
.nav-link{font-size:13px;font-weight:500;color:rgba(255,255,255,.6);text-decoration:none;letter-spacing:.06em;text-transform:uppercase;transition:color .2s;}
.nav-link:hover{color:var(--orange);}
.nav-cta{background:var(--orange);color:white;padding:9px 22px;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;transition:background .2s;}
.nav-cta:hover{background:var(--orange-l);}
@media(max-width:768px){nav{padding:0 20px;}.nav-links{gap:16px;}.nav-link{display:none;}}

/* HERO */
.hero{min-height:100vh;background:var(--dark);display:flex;flex-direction:column;justify-content:flex-end;padding:120px 48px 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:url('hero-bg.jpg') center center/cover no-repeat;filter:brightness(.35);}
.hero-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 70% 40%,rgba(232,68,26,.12) 0%,transparent 60%),radial-gradient(ellipse 40% 40% at 20% 80%,rgba(232,68,26,.06) 0%,transparent 50%);}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px);background-size:80px 80px;}
.hero-tag{font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--orange);margin-bottom:24px;position:relative;display:flex;align-items:center;gap:12px;}
.hero-tag::before{content:'';width:32px;height:1px;background:var(--orange);}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(72px,10vw,140px);line-height:.95;color:white;position:relative;margin-bottom:32px;}
.hero-title span{color:var(--orange);}
.hero-bottom{display:flex;align-items:flex-end;justify-content:space-between;gap:40px;position:relative;}
.hero-desc{max-width:480px;font-size:17px;font-weight:300;line-height:1.7;color:rgba(255,255,255,.55);}
.hero-actions{display:flex;gap:14px;flex-shrink:0;}
.btn{padding:14px 32px;font-size:13px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px;}
.btn-primary{background:var(--orange);color:white;}
.btn-primary:hover{background:var(--orange-l);transform:translateY(-1px);}
.btn-secondary{border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.7);}
.btn-secondary:hover{border-color:rgba(255,255,255,.5);color:white;}
@media(max-width:768px){.hero{padding:100px 20px 60px;}.hero-bottom{flex-direction:column;align-items:flex-start;}.hero-actions{flex-direction:column;width:100%;}.btn{justify-content:center;}}

/* TICKER */
.ticker{background:var(--orange);padding:14px 0;overflow:hidden;white-space:nowrap;}
.ticker-inner{display:inline-flex;animation:ticker 25s linear infinite;}
.ticker-item{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:.15em;color:white;padding:0 40px;display:flex;align-items:center;gap:40px;}
.ticker-item::after{content:'◆';font-size:8px;opacity:.6;}
@keyframes ticker{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* SECTION BASE */
.section{padding:100px 48px;}
.section-tag{font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--orange);margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.section-tag::before{content:'';width:24px;height:1px;background:var(--orange);}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(42px,5vw,68px);line-height:1;color:var(--charcoal);margin-bottom:20px;}
.section-sub{font-size:16px;font-weight:300;color:var(--mid);line-height:1.7;max-width:560px;}
@media(max-width:768px){.section{padding:60px 20px;}}

/* SERVICES */
#services{background:var(--dark);}
#services .section-title{color:white;}
#services .section-sub{color:rgba(255,255,255,.45);}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:60px;background:rgba(255,255,255,.06);}
.service-card{background:var(--dark);padding:44px 36px;transition:background .3s;position:relative;overflow:hidden;}
.service-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(232,68,26,.08),transparent);opacity:0;transition:opacity .3s;}
.service-card:hover::before{opacity:1;}
.service-card:hover{background:#222;}
.service-num{font-family:'Bebas Neue',sans-serif;font-size:48px;color:rgba(255,255,255,.06);line-height:1;margin-bottom:16px;}
.service-name{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:.04em;color:white;margin-bottom:12px;}
.service-desc{font-size:14px;font-weight:300;color:rgba(255,255,255,.45);line-height:1.7;}
.service-arrow{margin-top:20px;font-size:18px;color:var(--orange);opacity:0;transition:opacity .3s;}
.service-card:hover .service-arrow{opacity:1;}
@media(max-width:900px){.services-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.services-grid{grid-template-columns:1fr;}}

/* ABOUT */
#about{background:var(--off-white);}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-top:60px;}
.about-statement{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,4vw,56px);line-height:1.05;color:var(--charcoal);margin-bottom:24px;}
.about-statement span{color:var(--orange);}
.about-body{font-size:15px;font-weight:300;color:var(--mid);line-height:1.8;margin-bottom:20px;}
.about-stats{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:rgba(0,0,0,.06);}
.stat-box{background:var(--off-white);padding:28px 24px;}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:48px;color:var(--orange);line-height:1;}
.stat-label{font-size:12px;font-weight:400;color:var(--mid);margin-top:4px;letter-spacing:.04em;}
.skills-list{margin-top:2px;}
.skill-item{background:var(--off-white);padding:12px 24px;display:flex;align-items:center;gap:12px;font-size:13px;font-weight:500;color:var(--charcoal);border-bottom:2px solid rgba(0,0,0,.04);}
.skill-item::before{content:'';width:6px;height:6px;background:var(--orange);flex-shrink:0;}
@media(max-width:900px){.about-grid{grid-template-columns:1fr;gap:40px;}}

/* CONTACT */
#contact{background:var(--charcoal);}
#contact .section-title{color:white;}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-top:60px;}
.contact-detail{margin-bottom:28px;}
.contact-label{font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--orange);margin-bottom:6px;}
.contact-value{font-size:15px;font-weight:300;color:rgba(255,255,255,.7);}
.contact-value a{color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s;}
.contact-value a:hover{color:var(--orange);}
.form-group{margin-bottom:18px;}
.form-label{display:block;font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:7px;}
.form-input,.form-textarea{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:white;padding:13px 15px;font-size:14px;font-family:'Outfit',sans-serif;font-weight:300;outline:none;transition:border .2s;}
.form-input:focus,.form-textarea:focus{border-color:var(--orange);}
.form-textarea{resize:vertical;min-height:130px;}
.form-submit{width:100%;background:var(--orange);color:white;border:none;padding:15px;font-size:13px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s;font-family:'Outfit',sans-serif;}
.form-submit:hover{background:var(--orange-l);}
@media(max-width:900px){.contact-grid{grid-template-columns:1fr;gap:40px;}}

/* FOOTER */
footer{background:var(--dark);padding:28px 48px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid rgba(255,255,255,.06);}
.footer-logo{display:flex;align-items:center;gap:10px;}
.footer-sq{width:10px;height:10px;background:var(--orange);}
.footer-txt{font-family:'Bebas Neue',sans-serif;font-size:16px;color:rgba(255,255,255,.4);letter-spacing:.08em;}
.footer-copy{font-size:12px;color:rgba(255,255,255,.2);}
@media(max-width:600px){footer{flex-direction:column;gap:10px;text-align:center;padding:24px 20px;}}

/* ANIMATIONS */
.fade-up{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease;}
.fade-up.visible{opacity:1;transform:translateY(0);}
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="#home">
    <div class="nav-sq"></div>
    <span class="nav-txt">Strand Media</span>
  </a>
  <div class="nav-links">
    <a class="nav-link" href="#services">Services</a>
    <a class="nav-link" href="#about">About</a>
    <a class="nav-cta" href="#contact">Get in Touch</a>
  </div>
</nav>

<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-tag">Strand Media · Queenstown, NZ</div>
  <h1 class="hero-title">Design<br>That<br><span>Works.</span></h1>
  <div class="hero-bottom">
    <p class="hero-desc">Digital design for businesses that need creative solutions in print, brand, online and everything in between.</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="#services">Our Services</a>
      <a class="btn btn-secondary" href="#contact">Let's Talk</a>
    </div>
  </div>
</section>

<div class="ticker">
  <div class="ticker-inner">
    <span class="ticker-item">Raw Creative</span>
    <span class="ticker-item">Branding & Identity</span>
    <span class="ticker-item">Ink & Matter</span>
    <span class="ticker-item">Web Design</span>
    <span class="ticker-item">AI-Assisted Development</span>
    <span class="ticker-item">Advertising</span>
    <span class="ticker-item">Marketing Collateral</span>
    <span class="ticker-item">Raw Creative</span>
    <span class="ticker-item">Branding & Identity</span>
    <span class="ticker-item">Ink & Matter</span>
    <span class="ticker-item">Web Design</span>
    <span class="ticker-item">AI-Assisted Development</span>
    <span class="ticker-item">Advertising</span>
    <span class="ticker-item">Marketing Collateral</span>
  </div>
</div>

<section class="section" id="services">
  <div class="section-tag">What We Do</div>
  <h2 class="section-title">Services</h2>
  <p class="section-sub">Design expertise that suits your business and is what you need when you need it.</p>
  <div class="services-grid">
    <div class="service-card fade-up">
      <div class="service-num">01</div>
      <div class="service-name">Branding & Identity</div>
      <div class="service-desc">Logo design, brand guidelines, colour systems and visual identity built for print and digital from day one.</div>
      <div class="service-arrow">→</div>
    </div>
    <div class="service-card fade-up">
      <div class="service-num">02</div>
      <div class="service-name">Raw Creative</div>
      <div class="service-desc">Adobe suite expertise across Illustrator, Photoshop and InDesign. From concept to print-ready files.</div>
      <div class="service-arrow">→</div>
    </div>
    <div class="service-card fade-up">
      <div class="service-num">03</div>
      <div class="service-name">Ink & Matter</div>
      <div class="service-desc">Business cards, signage, packaging, catalogues and marketing collateral with deep print production knowledge.</div>
      <div class="service-arrow">→</div>
    </div>
    <div class="service-card fade-up">
      <div class="service-num">04</div>
      <div class="service-name">Web Design & Development</div>
      <div class="service-desc">Clean, fast, mobile-first websites designed and built to reflect your brand. Landing pages to full business sites.</div>
      <div class="service-arrow">→</div>
    </div>
    <div class="service-card fade-up">
      <div class="service-num">05</div>
      <div class="service-name">AI-Assisted Development</div>
      <div class="service-desc">Custom web apps, tools and automations — faster delivery and smarter solutions without the agency price tag.</div>
      <div class="service-arrow">→</div>
    </div>
    <div class="service-card fade-up">
      <div class="service-num">06</div>
      <div class="service-name">Advertising & Collateral</div>
      <div class="service-desc">Digital and print advertising, social assets and campaign materials that stay on-brand and get results.</div>
      <div class="service-arrow">→</div>
    </div>
  </div>
</section>

<section class="section" id="about">
  <div class="section-tag">About</div>
  <div class="about-grid">
    <div>
      <h2 class="about-statement">Expertise.<br><span>Contract flexibility.</span></h2>
      <p class="about-body">Strand Media is a Queenstown-based contract design studio bringing together design expertise, print production knowledge and a business degree to deliver design that works commercially as well as visually.</p>
      <p class="about-body">We work with businesses that need design skills without the commitment of a full-time hire — project by project, on your timeline.</p>
      <a class="btn btn-primary" href="#contact" style="margin-top:8px;">Start a Project</a>
    </div>
    <div>
      <div class="about-stats">
        <div class="stat-box"><div class="stat-num">15+</div><div class="stat-label">Years Experience</div></div>
        <div class="stat-box"><div class="stat-num">BMS</div><div class="stat-label">Waikato University</div></div>
        <div class="stat-box"><div class="stat-num">NZ</div><div class="stat-label">Queenstown Based</div></div>
        <div class="stat-box"><div class="stat-num">100%</div><div class="stat-label">Contract Work</div></div>
      </div>
      <div class="skills-list">
        <div class="skill-item">AI-Assisted Digital Solutions</div>
        <div class="skill-item">Web Design & Development</div>
        <div class="skill-item">Brand Strategy & Identity</div>
        <div class="skill-item">Raw Creative using latest software</div>
        <div class="skill-item">Pre Press & Ink Production</div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="contact">
  <div class="section-tag">Get In Touch</div>
  <h2 class="section-title">Let's Work<br>Together.</h2>
  <div class="contact-grid">
    <div>
      <p class="section-sub" style="color:rgba(255,255,255,.45);margin-bottom:48px;">Got a project in mind? Whether it's a brand refresh, a new website or an ongoing contract role — get in touch and let's talk.</p>
      <div class="contact-detail">
        <div class="contact-label">Email</div>
        <div class="contact-value"><a href="mailto:ash@strandmedia.co.nz">ash@strandmedia.co.nz</a></div>
      </div>
      <div class="contact-detail">
        <div class="contact-label">Location</div>
        <div class="contact-value">Queenstown, New Zealand</div>
      </div>
      <div class="contact-detail">
        <div class="contact-label">Website</div>
        <div class="contact-value"><a href="https://www.strandmedia.co.nz">strandmedia.co.nz</a></div>
      </div>
    </div>
    <div>
      <form action="https://formspree.io/f/mjgzqyje" method="POST">
        <div class="form-group">
          <label class="form-label">Your Name *</label>
          <input class="form-input" type="text" name="name" required placeholder="Max Power"/>
        </div>
        <div class="form-group">
          <label class="form-label">Email Address *</label>
          <input class="form-input" type="email" name="email" required placeholder="max@company.co.nz"/>
        </div>
        <div class="form-group">
          <label class="form-label">What do you need?</label>
          <input class="form-input" type="text" name="subject" placeholder="Brand identity, website, print design…"/>
        </div>
        <div class="form-group">
          <label class="form-label">Tell me more *</label>
          <textarea class="form-textarea" name="message" required placeholder="Brief description of your project, timeline and budget…"></textarea>
        </div>
        <button class="form-submit" type="submit">Send Message →</button>
      </form>
    </div>
  </div>
</section>

<footer>
  <div class="footer-logo">
    <div class="footer-sq"></div>
    <span class="footer-txt">Strand Media</span>
  </div>
  <span class="footer-copy">© 2026 Strand Media. All rights reserved.</span>
</footer>

<script>
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
},{threshold:0.1});
document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));

window.addEventListener('scroll',()=>{
  const sections=document.querySelectorAll('section[id]');
  let cur='';
  sections.forEach(s=>{if(window.scrollY>=s.offsetTop-100)cur=s.id;});
  document.querySelectorAll('.nav-link').forEach(l=>{
    l.style.color=l.getAttribute('href')==='#'+cur?'var(--orange)':'';
  });
});
</script>
</body>
</html>
